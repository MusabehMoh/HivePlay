# HivePlay Environment Variables (Optional)
# These are already set with defaults in docker-compose.yml

# Node Environment
NODE_ENV=production

# Redis Connection
REDIS_URL=redis://redis:6379

# yt-dlp Auto-Update
YTDLP_AUTO_UPDATE=true
YTDLP_UPDATE_CHECK_INTERVAL=86400

# Next.js Settings
NEXT_TELEMETRY_DISABLED=1

# Custom Settings (Optional)
# Uncomment and modify if needed
# PORT=3000
# REDIS_PASSWORD=your_password_here
